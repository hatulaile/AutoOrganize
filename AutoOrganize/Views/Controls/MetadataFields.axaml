<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AutoOrganize.Views.Controls">
    <Design.PreviewWith>
        <Border Padding="12">
            <controls:MetadataFields Title="地区" Value="中国" Prefix="Pre" Suffix="Suf" />
        </Border>
    </Design.PreviewWith>

    <Style Selector="controls|MetadataFields">
        <!-- Set Defaults -->
        <Setter Property="Template">
            <ControlTemplate>
                <TextBlock TextWrapping="{TemplateBinding TextWrapping}">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}: {1}{2}{3}">
                            <Binding Path="Title" RelativeSource="{RelativeSource TemplatedParent}" />
                            <Binding Path="Prefix" RelativeSource="{RelativeSource TemplatedParent}" />
                            <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}" />
                            <Binding Path="Suffix" RelativeSource="{RelativeSource TemplatedParent}" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
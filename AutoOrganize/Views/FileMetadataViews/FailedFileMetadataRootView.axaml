<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AutoOrganize.ViewModels.FileMetadataViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:FailedFileMetadataRootViewModel"
             x:Class="AutoOrganize.Views.FileMetadataViews.FailedFileMetadataRootView">
    
    <Border Padding="8">
        <TextBlock HorizontalAlignment="Center" FontSize="24">
            <TextBlock.Text>
                <MultiBinding StringFormat="发生错误的文件: {0}">
                    <Binding Mode="OneWay" Path="ErrorCount"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>
    </Border>
</UserControl>

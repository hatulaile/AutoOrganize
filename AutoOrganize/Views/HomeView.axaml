<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AutoOrganize.ViewModels"
             xmlns:controls="using:AutoOrganize.Views.Controls"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="576"
             x:Class="AutoOrganize.Views.HomeView"
             x:DataType="vm:HomeViewModel">

    <controls:RoutedViewHost Router="{Binding RoutingState}" />
</UserControl>
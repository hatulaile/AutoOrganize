<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AutoOrganize.ViewModels"
             xmlns:control="using:AutoOrganize.Views.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AutoOrganize.Views.MetadataEditView"
             x:DataType="vm:MetadataEditViewModel">

    <UserControl.Resources>
    </UserControl.Resources>

    <Border Padding="18,18,18,8">
        <Grid RowDefinitions="*,Auto">
            <Border Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*" MinWidth="40" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="4*" MinWidth="40" />
                    </Grid.ColumnDefinitions>

                    <TreeDataGrid
                        Grid.Column="0"
                        BorderThickness="2,2,0,2"
                        BorderBrush="{DynamicResource SystemControlTransientBackgroundBrush}"
                        Source="{Binding Source}"
                        CanUserSortColumns="False">

                        <!-- todo: 右键菜单 -->
                        <TreeDataGrid.ContextFlyout>
                            <MenuFlyout></MenuFlyout>
                        </TreeDataGrid.ContextFlyout>
                    </TreeDataGrid>

                    <GridSplitter Grid.Column="1"
                                  ShowsPreview="False"
                                  Margin="0,0,1,0"
                                  Background="{DynamicResource SystemControlTransientBackgroundBrush}">
                        <GridSplitter.Styles>
                            <Style Selector="GridSplitter">
                                <Setter Property="MinWidth" Value="3" />
                                <Setter Property="MinHeight" Value="4" />
                            </Style>
                        </GridSplitter.Styles>
                    </GridSplitter>

                    <Border Grid.Column="2"
                            BorderBrush="{DynamicResource SystemControlTransientBackgroundBrush}"
                            BorderThickness="2">
                        <control:RoutedViewHost Router="{Binding RoutingState}"
                                                IsVisible="{Binding RoutingState.CurrentPageViewModel, Converter={x:Static ObjectConverters.IsNotNull}}">

                            <control:RoutedViewHost.PageTransition>
                                <x:Null />
                            </control:RoutedViewHost.PageTransition>
                        </control:RoutedViewHost>
                    </Border>
                </Grid>
            </Border>

            <Panel Grid.Row="1" HorizontalAlignment="Stretch" Margin="0,8,0,0">
                <Button HorizontalContentAlignment="Left" Command="{Binding BackCommand}">
                    <TextBlock Text="上一页" LetterSpacing="2" />
                </Button>
                <Button HorizontalAlignment="Right" Command="{Binding NextCommand}">
                    <TextBlock Text="继续" LetterSpacing="4" />
                </Button>
            </Panel>
        </Grid>
    </Border>
</UserControl>